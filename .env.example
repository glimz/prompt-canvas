# OpenAI key used only by backend for image generation.
# Never expose this value in frontend env files.
OPENAI_API_KEY=your_openai_api_key

# App and company branding shown in UI defaults.
# Admin settings can override and persist these values.
APP_NAME=PromptCanvas Demo Studio
COMPANY_NAME=PromptCanvas Demo

# Default image provider for generation (openai or pollinations).
IMAGE_PROVIDER=openai
POLLINATIONS_MODEL=flux
OPENAI_TIMEOUT_MS=120000
POLLINATIONS_TIMEOUT_MS=60000
SERVICE_RETRY_MAX_ATTEMPTS=3
SERVICE_RETRY_BASE_DELAY_MS=1200

# API server port.
PORT=8787

# Frontend origin allowed by backend CORS.
# Local example: http://localhost:5173
# Hosted example: https://app.yourdomain.com
ALLOWED_ORIGIN=http://localhost:5173

# Enable Supabase token verification on protected routes.
# true = auth required, false = local dev bypass mode.
AUTH_ENABLED=true

# Supabase JWT secret used to verify access tokens on backend.
# In local Supabase Docker, use the JWT secret from your Supabase config.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Comma-separated admin emails allowed to view admin logs endpoint.
ADMIN_EMAILS=admin@example.com

# Optional Discord notifications for audit events.
# Set DISCORD_NOTIFICATION to a Discord webhook URL directly, or to "true" and set DISCORD_WEBHOOK_URL.
# Notifications are best-effort and never block API responses.
DISCORD_NOTIFICATION=
DISCORD_WEBHOOK_URL=

# Public base URL used in Discord embeds to build image links.
# If unset, backend falls back to request host/protocol.
# Example: https://demo.yourdomain.com
DISCORD_PUBLIC_BASE_URL=

# Optional local bypass login (useful when Supabase signup/email is unavailable).
# If enabled, frontend can call /api/auth/test-login with these credentials.
TEST_LOGIN_ENABLED=false
TEST_LOGIN_EMAIL=test@example.com
TEST_LOGIN_PASSWORD=change_me
TEST_LOGIN_TOKEN=dev-test-token
