# Backend API base URL used by the React app.
# Local example: http://localhost:8787
# Hosted example: https://api.yourdomain.com
VITE_API_BASE=http://localhost:8787

# Supabase project URL for client-side auth.
# In this repo's detected local Docker setup, Kong is exposed on :8888.
# Use your own local gateway URL if different.
VITE_SUPABASE_URL=http://localhost:8888

# Supabase public anon key (safe for frontend use).
# Do NOT use service_role key in frontend env.
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Comma-separated public hostnames allowed by Vite dev server.
# Example: prompt-canvas-demo.talenttic.co,app-prompt-canvas-demo.talenttic.co
VITE_ALLOWED_HOSTS=
